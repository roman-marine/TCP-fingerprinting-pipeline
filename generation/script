smbclient //10.0.3.102/share --user samba%samba --command "ls; put random.txt; exit"
smbclient //10.0.3.102/share --user samba%samba --command "ls; prompt OFF; rm random.txt; exit"
# mount
sudo mkdir /mnt/smb_share
echo -e "username=samba\npassword=samba" > /tmp/sambacred.txt
sudo mount -t cifs -o credentials=/tmp/sambacred.txt //10.0.3.102/share /mnt/smb_share
sleep 2
cd /mnt/smb_share
ls -la
cd /mnt/smb_share/Folder
ls -la
sudo cp -a * /tmp/Folder
sudo rm -f *
