# folder
cd /tmp
mkdir /tmp/FFolder
mkdir /tmp/Folder
cd /tmp/FFolder
sleep 1
smbclient //10.0.3.102/share --user samba%samba --command "ls; recurse ON; prompt OFF; cd Folder; mget *; recurse OFF; exit"
for i in $(seq 1 30);
do
    echo $i;
    n=$(shuf --random-source=/dev/urandom -n 1 -i 19000-160000);
    head -c $n /dev/urandom | base64 > random.txt;
    smbclient //10.0.3.102/share --user samba%samba --command "cd Folder; put random.txt random$i.txt; exit";
done

# upload
n=$(shuf --random-source=/dev/urandom -n 1 -i 19000-160000);
