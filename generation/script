# SMB
smbclient -L //10.0.3.102 --user samba%samba
sleep 1
smbclient //10.0.3.102/share --user samba%samba --command "ls; get sshkey /home/user/sshkey; exit"
sleep 1
smbclient //10.0.3.102/share --user samba%samba --command "get ranking.txt /home/user/ranking.txt; exit"
